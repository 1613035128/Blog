.hero-section
  position: fixed
  top: 0
  left: 0
  width: 100vw
  height: 100vh
  overflow: hidden
  z-index: 1

.background-slider
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  z-index: 1

.bg-image
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  background-size: cover
  background-position: center
  background-repeat: no-repeat
  opacity: 0
  transform: scale(1.05)
  transition: opacity 800ms ease-in-out, transform 6000ms ease-out
  z-index: 1

  &.active
    opacity: 1
    transform: scale(1)
    z-index: 2

.hero-content
  position: absolute
  top: 50%
  left: 50%
  transform: translate(-50%, -50%)
  text-align: center
  z-index: 10
  color: #fff
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5)
  pointer-events: none

.hero-title
  font-size: 4rem
  font-weight: 700
  margin: 0 0 1rem 0
  letter-spacing: 0.5rem
  animation: fadeInUp 1s ease-out

.hero-subtitle
  font-size: 1.2rem
  font-weight: 300
  margin: 0
  opacity: 0.9
  animation: fadeInUp 1s ease-out 0.3s both
  max-width: 600px
  line-height: 1.6

.nav-zones
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  display: flex
  z-index: 5

.nav-zone
  height: 100%
  cursor: pointer
  transition: background-color 0.3s ease

  &:hover
    background-color: rgba(255, 255, 255, 0.05)

.nav-zone-left
  width: 20%

.nav-zone-center
  width: 60%
  cursor: default

  &:hover
    background-color: transparent

.nav-zone-right
  width: 20%

.nav-hints
  position: absolute
  top: 50%
  left: 0
  width: 100%
  transform: translateY(-50%)
  display: flex
  justify-content: space-between
  padding: 0 2rem
  pointer-events: none
  z-index: 6

.nav-hint
  font-size: 3rem
  color: rgba(255, 255, 255, 0.3)
  transition: color 0.3s ease, opacity 0.3s ease
  opacity: 0

.nav-zone-left:hover ~ .nav-hints .nav-hint-left,
.nav-zone-right:hover ~ .nav-hints .nav-hint-right
  opacity: 1
  color: rgba(255, 255, 255, 0.6)

@keyframes fadeInUp
  from
    opacity: 0
    transform: translateY(30px)
  to
    opacity: 1
    transform: translateY(0)

@media (max-width: 768px)
  .hero-title
    font-size: 2.5rem
    letter-spacing: 0.3rem

  .hero-subtitle
    font-size: 1rem
    padding: 0 2rem

  .nav-hint
    font-size: 2rem
